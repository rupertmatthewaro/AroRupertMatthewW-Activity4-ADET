@{
    ViewData["Title"] = "Home";
}

<!-- HOME -->
<section class="hero" id="home">
    <div class="hero-inner">
        <p class="hero-greeting">Hello, and welcome to my portfolio!</p>
        <div class="hero-layout">
            <div class="hero-text">
                <h1 class="hero-name">Rupert Matthew Aro</h1>
                <p class="hero-title">Aspiring Data Scientist &amp; Cloud Computing Enthusiast</p>
                <p class="hero-tagline">Learning, building, and improving every step of the way.</p>
            </div>
            <div class="hero-img-wrap">
                <img src="~/images/profile.jpg" alt="Rupert Matthew W. Aro" />
            </div>
        </div>
    </div>
</section>

<!-- ABOUT -->
<section id="about">
    <div class="section-inner">
        <h2 class="section-title" id="about-title">About Me</h2>
        <div class="section-divider" id="about-divider"></div>
        <div class="about-content">
            <p class="about-intro">
                I am Rupert Matthew Aro, an Information Technology student who is passionate about exploring how
                technology can be used to solve real-world problems. I am continuously developing my skills in my
                fields of interest as part of my academic and personal growth.
            </p>
            <p class="about-body">
                I am a curious and goal-driven student who enjoys learning how systems work behind the scenes.
                I also value consistency, discipline, and continuous improvement in my tasks.
                One of my key strengths is being meticulous, which helps me ensure accuracy and great quality in everything that I do.
            </p>
            <div class="about-details">
                <div class="about-detail-item">
                    <span class="about-detail-label">Course</span>
                    <span class="about-detail-value">Bachelor of Science in Information Technology</span>
                </div>
                <div class="about-detail-item">
                    <span class="about-detail-label">Career Goal</span>
                    <span class="about-detail-value">To land a field in data science or cloud computing</span>
                </div>
                <div class="about-detail-item">
                    <span class="about-detail-label">Interests</span>
                    <span class="about-detail-value">Data-driven technologies, cloud systems, distributed computing</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SKILLS -->
<section id="skills">
    <div class="section-inner">
        <h2 class="section-title" id="skills-title">My Skills</h2>
        <div class="section-divider" id="skills-divider"></div>

        <div class="skills-group">
            <p class="skills-group-title">Soft Skills</p>
            <div class="skills-grid">
                <div class="skill-card">
                    <h4>Leadership</h4>
                    <p>Experience in guiding group tasks and organizing academic projects effectively.</p>
                </div>
                <div class="skill-card">
                    <h4>Problem-solving</h4>
                    <p>Able to break down logic problems into structured, step-by-step solutions.</p>
                </div>
                <div class="skill-card">
                    <h4>Adaptability</h4>
                    <p>Quick to adjust to new tools, technologies, and learning environments.</p>
                </div>
                <div class="skill-card">
                    <h4>Detail-oriented</h4>
                    <p>Focused on accuracy, especially in documentation and system design.</p>
                </div>
            </div>
        </div>

        <div class="skills-group">
            <p class="skills-group-title">Technical Skills</p>
            <div class="skills-grid">
                <div class="skill-card">
                    <h4>Database Design</h4>
                    <p>Strong understanding of relational database structures and SQL queries.</p>
                </div>
                <div class="skill-card">
                    <h4>Networking Concepts</h4>
                    <p>Knowledge of basic networking principles learned through coursework and labs.</p>
                </div>
                <div class="skill-card">
                    <h4>Quality Assurance</h4>
                    <p>Experience in testing systems for errors, usability issues, and improvements.</p>
                </div>
                <div class="skill-card">
                    <h4>Research &amp; Analysis</h4>
                    <p>Able to gather, analyze, and interpret technical information for projects.</p>
                </div>
                <div class="skill-card">
                    <h4>Programming Languages</h4>
                    <p>MySQL, Python, PHP — used in academic exercises and system development practice.</p>
                </div>
                <div class="skill-card">
                    <h4>Data Science &amp; ML</h4>
                    <p>Foundational understanding of data processing, classification, and model basics.</p>
                </div>
                <div class="skill-card">
                    <h4>Cloud Computing</h4>
                    <p>Basic knowledge of cloud systems and distributed computing principles.</p>
                </div>
            </div>
        </div>
    </div>
</section>

