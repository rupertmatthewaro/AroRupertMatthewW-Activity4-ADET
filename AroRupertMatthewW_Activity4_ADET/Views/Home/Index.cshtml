@section Scripts {
    <script>
        function fitDivider(titleId, dividerId) {
            var title = document.getElementById(titleId);
            var divider = document.getElementById(dividerId);
            if (title && divider) {
                divider.style.width = title.offsetWidth + 'px';
            }
        }
        function fitAllDividers() {
            fitDivider('about-title', 'about-divider');
            fitDivider('skills-title', 'skills-divider');
            fitDivider('projects-title', 'projects-divider');
            fitDivider('contact-title', 'contact-divider');
        }
        document.addEventListener('DOMContentLoaded', fitAllDividers);
        window.addEventListener('resize', fitAllDividers);
    </script>
}